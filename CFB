<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CFB Stats Dashboard</title>

<style>
body{
  margin:0;
  font-family:Arial,sans-serif;
  background:#0b0b0b;
  color:white;
}

header{
  padding:18px;
  background:#111;
  border-bottom:2px solid #d4af37;
  display:flex;
  justify-content:space-between;
}

h1{color:#d4af37;margin:0}

.container{padding:20px}

input{
  padding:10px;
  width:260px;
  margin-bottom:15px;
}

table{
  width:100%;
  border-collapse:collapse;
}

th,td{
  padding:10px;
  border-bottom:1px solid #222;
}

th{
  color:#d4af37;
  cursor:pointer;
}

tr:hover{background:#1a1a1a}
</style>
</head>

<body>

<header>
<h1>GRIDIRON CENTRAL</h1>
<div>CFB STATS</div>
</header>

<div class="container">

<input id="search" placeholder="Search player..." oninput="render()">

<table>
<thead>
<tr>
<th onclick="sort('player')">Player</th>
<th onclick="sort('team')">Team</th>
<th onclick="sort('yds')">YDS</th>
<th onclick="sort('td')">TD</th>
</tr>
</thead>
<tbody id="body"></tbody>
</table>

</div>

<script>

const DATA = [
{player:"Caleb Williams",team:"USC",yds:3633,td:37},
{player:"Bo Nix",team:"Oregon",yds:4045,td:45},
{player:"Jayden Daniels",team:"LSU",yds:3812,td:40},
{player:"Marvin Harrison Jr",team:"Ohio State",yds:1211,td:14},
{player:"Rome Odunze",team:"Washington",yds:1640,td:13}
];

let sortKey=null;
let dir=-1;

function getData(){
let q=document.getElementById("search").value.toLowerCase();
let d=[...DATA];

if(q) d=d.filter(p=>p.player.toLowerCase().includes(q));

if(sortKey){
d.sort((a,b)=>((a[sortKey]||0)-(b[sortKey]||0))*dir);
}

return d;
}

function render(){
document.getElementById("body").innerHTML =
getData().map(p=>`
<tr>
<td>${p.player}</td>
<td>${p.team}</td>
<td>${p.yds}</td>
<td>${p.td}</td>
</tr>
`).join("");
}

function sort(k){
if(sortKey===k) dir*=-1;
else {sortKey=k;dir=-1;}
render();
}

render();

</script>

</body>
</html>
